VITE_GEMINI_KEY=coloque_sua_chave_aqui
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Opcional: true habilita bloco de login por magic link (Task #14)
VITE_FEATURE_MAGIC_LINK=false

# Convex (DESENVOLVIMENTO LOCAL)
# - Use URL do deployment de desenvolvimento local/remoto de Dev
# - NUNCA usar URL de Producao em .env.local
VITE_CONVEX_URL_DEV=

# Convex (PRODUCAO)
# - Configure apenas no provedor (ex: Vercel), nao no .env.local
VITE_CONVEX_URL_PROD=

# Convex (OPCIONAL)
# - Se definido, sobrescreve a escolha automatica Dev/Prod
# - Use somente quando souber exatamente qual deployment quer apontar
VITE_CONVEX_URL=
